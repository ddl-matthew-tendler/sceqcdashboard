# Domino API Configuration
# Copy this file to .env and fill in your values

# Required: Base URL of the Domino instance (no trailing slash)
DOMINO_API_HOST=https://life-sciences-demo.domino-eval.com

# Optional: Static API key (bypasses token endpoint at localhost:8899)
# When running locally outside Domino, you MUST set this.
# Get your key from: Domino → Account Settings → API Key
API_KEY_OVERRIDE=
